PORT=3020
AGENT_MODE=local_deterministic
AGENT_RUNTIME=crewai_llm

# Agentathon / Compass OpenAI-compatible aliases. These are supported directly
# for evaluator compatibility. The reusable Parallax42 gateway vars below remain
# preferred for the hosted demo boundary.
OPENAI_API_KEY=your-compass-api-key-here
OPENAI_BASE_URL=https://compass.core42.ai/v1
MODEL_NAME=gpt-4.1
REASONING_MODEL_NAME=gpt-5.1
EMBEDDING_MODEL_NAME=text-embedding-3-large
SAMPLE_MODE=false

PARALLAX42_BACKEND_URL=https://api.parallax42.bhavukarora.com
PARALLAX42_DEMO_UI_URL=https://slackspac3.github.io/Parallax42/
COMPASS_GATEWAY_BASE_URL=https://parallax42-compass-gateway.vercel.app/api
COMPASS_GATEWAY_URL=https://parallax42-compass-gateway.vercel.app/api/compass
COMPASS_GATEWAY_TOKEN=
EMBEDDINGS_MODEL=text-embedding-3-large
P42_WORKSPACE_ID=parallax42
P42_PROJECT_ID=compliance-intelligence-agent
P42_REQUIRE_DURABLE_STORAGE=0
P42_VECTOR_STORE_PROVIDER=qdrant
# Full RAG requires these server-side Qdrant values. Without them the app falls back to local-file demo storage.
# QDRANT_URL=https://<cluster>.cloud.qdrant.io
# QDRANT_API_KEY=
# QDRANT_COLLECTION=p42_compliance_evidence
# Run `npm run qdrant:smoke` after setting these to verify full RAG and governed learning memory.

# Advanced components are requested by default and can be switched off through /api/admin/features.
P42_FEATURE_COMPASS_LLM_CALLS=1
P42_FEATURE_COMPASS_EMBEDDINGS=1
P42_FEATURE_QDRANT_RAG=1
P42_FEATURE_QDRANT_LEARNING_MEMORY=1
P42_FEATURE_EXTERNAL_PARSER_RELAY=1
P42_FEATURE_LIVE_ADVISORY_SPECIALISTS=1
P42_FEATURE_LIVE_CREWAI=1
# Optional: persist admin feature switches somewhere explicit instead of OS tmp.
# P42_ADMIN_FEATURE_CONFIG_PATH=/var/lib/parallax42-compliance-agent/admin-feature-flags.json

# Live CrewAI / advisory specialists through the same OpenAI-compatible gateway.
CREWAI_ENABLE_LIVE_LLM=1
CREWAI_LLM_MODEL=gpt-5.1
CREWAI_LLM_BASE_URL=https://parallax42-compass-gateway.vercel.app/api
# CREWAI_LLM_API_KEY=<same-value-as-COMPASS_GATEWAY_TOKEN>
# Vercel cannot run the Python CrewAI adapter directly; delegate live CrewAI to the droplet service.
P42_CREWAI_SERVICE_URL=https://api.parallax42.bhavukarora.com/crewai
# P42_CREWAI_SERVICE_TOKEN=<long-random-service-token>

# RBAC/authentication. Keep audit mode for public demos; use enforced in private enterprise deployments.
P42_AUTH_MODE=audit
# P42_AUTH_MODE=enforced
# P42_AUTH_AUDIENCE=api://parallax42-compliance-agent
# P42_AUTH_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# P42_ENTRA_TENANT_ID=<tenant-id>
# P42_ENTRA_JWKS_URL=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys

# Local/smoke-test token option for private demos. Do not use as the enterprise auth control.
# P42_DEMO_BEARER_TOKEN=<long-random-token>
# P42_DEMO_ACTOR=reviewer@example.com
# P42_DEMO_ROLES=compliance_reviewer,auditor

# Audit storage. Configure this to durable mounted storage in production.
# P42_AUDIT_STORE_PROVIDER=managed_append_only
# AGENT_AUDIT_DIR=/var/lib/parallax42-compliance-agent/audit

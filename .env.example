# Agentathon evaluator / Compass-compatible API placeholders.
# These values follow the official Agentathon Compass template.
# Production may use the project owner's rotated Compass credentials, while the
# public deterministic demo can use explicitly labelled hash embeddings. Never
# commit real keys or assume an Agentathon-issued key is present.
OPENAI_API_KEY=replace-with-your-compass-api-key
OPENAI_BASE_URL=https://compass.core42.ai/v1
# Alternate Core42 public API base if Core42/Agentathon confirms it for the issued key:
# OPENAI_BASE_URL=https://api.core42.ai/v1
# Fast/default chat model for structured intake, JSON advisory, and lower-latency tasks.
MODEL_FAST=gpt-4.1
# Reasoning/deeper advisory model for specialist council and final advisory review.
MODEL_REASONING=gpt-5.1
# Embedding model for evidence, reference, and learning-memory retrieval.
EMBEDDING_MODEL=text-embedding-3-large
WHISPER_MODEL=whisper-1
SAMPLE_MODE=false
REQUIRE_COMPASS=true
PORT=8000
LOG_DIR=./logs
MAX_RUNTIME_SECONDS=120

# Existing Parallax42 app options. Keep values placeholder-only in git.
P42_AUTH_MODE=enforced
# FastAPI evaluator bearer identity. Set a random deployment secret; leave blank only in local audit mode.
P42_DEMO_BEARER_TOKEN=
P42_DEMO_ACTOR_ID=agentathon-reviewer
P42_DEMO_ROLES=compliance_reviewer,auditor
# Durable v2 session, access-code, quota, case-lifecycle, and hosted audit-chain store.
# Hosted runtimes fail audit writes closed when this is absent; JSONL is local/test-only.
DATABASE_URL=
# Local template default; set to 1 in hosted deployment (hosted audit also fails closed automatically).
P42_REQUIRE_DURABLE_STORAGE=0
# Optional local/test audit JSONL directory. Do not set this as hosted durability.
AGENT_AUDIT_DIR=./logs
# Comma-separated, random 12+ character one-time pilot codes. Keep this only in the deployment secret store.
P42_PILOT_ACCESS_CODES=
P42_PILOT_ROLES=compliance_reviewer,business_approver
P42_ALLOWED_ORIGINS=https://slackspac3.github.io,http://127.0.0.1:3020,http://localhost:3020
P42_WORKSPACE_ID=parallax42-agent-v2
P42_PROJECT_ID=compliance-intelligence-agent-v2
P42_VECTOR_STORE_PROVIDER=qdrant
# Deterministic lexical hash vectors for a credential-free public demo. This is
# real retrieval behavior, but it must not be described as Compass semantics.
P42_DEMO_EMBEDDINGS=false
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=p42_compliance_evidence_v2
QDRANT_VECTOR_SIZE=3072
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=120
AGENT_RUNTIME=custom
CREWAI_ENABLE_LIVE_LLM=0

# Optional gateway aliases used by the existing Node runtime.
COMPASS_GATEWAY_BASE_URL=
COMPASS_GATEWAY_URL=
COMPASS_GATEWAY_TOKEN=
CREWAI_LLM_MODEL=gpt-5.1
CREWAI_LLM_BASE_URL=
CREWAI_LLM_API_KEY=
P42_CREWAI_SERVICE_URL=
P42_CREWAI_SERVICE_TOKEN=

# Legacy model aliases accepted by existing Node modules.
MODEL_NAME=gpt-4.1
REASONING_MODEL_NAME=gpt-5.1
EMBEDDINGS_MODEL=text-embedding-3-large
